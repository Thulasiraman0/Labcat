pipeline {
    agent any

    stages {
        stage('Task 1: Checkout') {
            steps {
                // Pulls the latest changes from your GitHub repository
                checkout scm
                echo "Repository updated successfully."
            }
        }

        stage('Task 2: Append Status Message') {
            steps {
                // '>>' tells Windows to add text to the END of the file
                // If the file doesn't exist, it will create it first.
                bat 'echo Pipeline Execution Completed >> status.txt'
                
                echo "The completion message has been appended to status.txt."
            }
        }

        stage('Task 3: Display Final Status') {
            steps {
                echo "--- Showing full status.txt history ---"
                // Change 'bat' to 'type' here
                bat 'type status.txt'
            }
        }
    }
}
