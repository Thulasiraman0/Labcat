pipeline {
    agent any

    stages {
        stage('Task 1: Checkout') {
            steps {
                // Pulls the latest version of your code from GitHub
                checkout scm
                echo "Latest commit has been pulled successfully."
            }
        }

        stage('Task 2 & 3: Create and Write Log') {
            steps {
                script {
                    // Create the file and write a message into it
                    // The '>' symbol creates a new file (or overwrites if it exists)
                    bat 'echo Build process started at %TIME% on %DATE% > buildlog.txt'
                    
                    // Append another line using '>>'
                    bat 'echo Status: Workspace initialized and logged. >> buildlog.txt'
                    
                    echo "File 'buildlog.txt' has been created."
                }
            }
        }

        stage('Task 3: Display Log Contents') {
            steps {
                echo "--- Displaying buildlog.txt Content ---"
                // 'type' is the Windows command to read and show file text
                bat 'type buildlog.txt'
            }
        }
    }
}
